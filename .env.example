# ─────────────────────────────────────────────────────────────────────────────
# Echo environment configuration.
#
# Copy this file to `.env` (which is git-ignored) and edit the values below:
#   cp .env.example .env
#
# `docker compose` reads `.env` automatically. These are machine-specific
# values only — all service behavior lives in the YAML files under configs/.
# ─────────────────────────────────────────────────────────────────────────────

# Which embedder image a bare `docker compose up` starts: `cpu` or `gpu`.
#   - cpu: works everywhere, no special setup.
#   - gpu: needs nvidia-container-toolkit installed on the host.
# Override per run without editing this file: `docker compose --profile gpu up`.
COMPOSE_PROFILES=cpu

# Where the embedding model weights are cached on the HOST. This is bind-mounted
# into the embedder so models aren't re-downloaded on each rebuild.
# Leave the default unless your Hugging Face cache lives elsewhere.
HF_CACHE_PATH=${HOME}/.cache/huggingface

# HOST directory that holds the prebuilt FAISS / BM25 index, mounted to
# /app/indexes in the retrieval container. The files inside must match
# configs/retrieval/api.yaml:index_path and configs/sparse_store/bm25.yaml:path.
# Point this at wherever you saved your index (see "Building an index" in README).
INDEX_PATH_DIR=./indexes

# HOST ports each service is published on. Change any that collide with something
# already running on your machine; the in-container ports are fixed.
EMBEDDER_PORT=8080      # embedder API        -> http://localhost:8080
RETRIEVAL_PORT=8090     # retrieval API       -> http://localhost:8090
GENERATION_PORT=8100    # generation/LLM API  -> http://localhost:8100 (docs at /docs)
FRONTEND_PORT=3000      # chat UI             -> http://localhost:3000

# Secret that gates account registration (POST /auth/register). If set here it
# OVERRIDES configs/auth/api.yaml:signup_secret, so the real value never lands in
# git — set it for any real deployment. Leave commented to fall back to the YAML
# placeholder. Set it to an empty value to disable registration entirely.
# ECHO_SIGNUP_SECRET=change-me

# ─────────────────────────────────────────────────────────────────────────────
# Reminder: the LLM itself runs in Ollama on the HOST, not in Docker.
# Make sure Ollama is running and the model in configs/generation/llm.yaml is
# pulled (`ollama pull <model>`). The generation container reaches it at
# host.docker.internal:11434 — no env var needed here.
# ─────────────────────────────────────────────────────────────────────────────
